# Copy to infra/.env and edit. Do NOT commit infra/.env to git.
#
# Generate a strong JWT secret (run once in your terminal):
#   python3 -c "import secrets; print(secrets.token_hex(32))"

POSTGRES_USER=ite
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ite

ITE_DATABASE_URL=postgresql+psycopg://ite:changeme@postgres:5432/ite
ITE_ENV=production
ITE_JWT_SECRET=dev-only-change-me-32-chars-min-please

# Set this to the URL where the app is accessible, e.g. http://192.168.1.50
# or http://localhost if only used on this machine.
ITE_ALLOWED_ORIGINS=http://localhost
